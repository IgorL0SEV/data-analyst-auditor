# Data Analyst Agent — Portfolio Edition

# Database connection (SQLAlchemy-compatible)
# DATABASE_URL=postgresql://user:***@host:port/dbname

# NocoDB connection
NOCODB_BASE_URL=https://nocodb.example.com
NOCODB_API_TOKEN=your_api_token

# Paths (relative to project root)
DATA_ANALYST_DATA_DIR=data
DATA_ANALYST_LOGS_DIR=logs
DATA_ANALYST_TEMP_DIR=temp

# Optional: SQL database for query_db.py
# DATABASE_URL=postgresql://user:***@host:port/dbname

# LLM backend: openai | ollama
LLM_BACKEND=openai

# --- OpenAI settings ---
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
# Optional custom base URL for OpenAI-compatible providers
# OPENAI_BASE_URL=https://api.openai.com/v1

# --- Ollama settings (local or self-hosted) ---
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2
# Optional API token if your Ollama endpoint requires auth
# OLLAMA_API_TOKEN=...
